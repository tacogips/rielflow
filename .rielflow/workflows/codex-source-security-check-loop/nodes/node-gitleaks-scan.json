{
  "id": "gitleaks-scan",
  "description": "Run gitleaks secret detection when the gitleaks executable is available.",
  "nodeType": "command",
  "variables": {},
  "command": {
    "scriptPath": "scripts/source-security-scan.bash",
    "argvTemplate": [
      "{{workflowInput.targetPath}}"
    ],
    "envTemplate": {
      "SECURITY_SCAN_MODE": "gitleaks",
      "SECURITY_INCLUDE_PATHS": "{{workflowInput.includePaths}}",
      "SECURITY_EXCLUDE_PATHS": "{{workflowInput.excludePaths}}",
      "SECURITY_MAX_FINDINGS": "{{workflowInput.maxFindings}}",
      "SECURITY_RUN_NETWORK_AUDITS": "{{workflowInput.runNetworkAudits}}"
    }
  },
  "output": {
    "description": "Return deterministic method JSON matching this schema.",
    "jsonSchema": {
      "type": "object",
      "required": ["status", "scanMode", "targetPath", "includePaths", "excludePaths", "scanRoots", "maxFindings", "runNetworkAudits", "tools", "manifests", "commands", "findings", "severityCounts", "coverageGaps", "notes"],
      "properties": {
        "status": { "type": "string" },
        "scanMode": { "type": "string" },
        "targetPath": { "type": "string" },
        "includePaths": { "type": "array", "items": { "type": "string" } },
        "excludePaths": { "type": "array", "items": { "type": "string" } },
        "scanRoots": { "type": "array", "items": { "type": "string" } },
        "maxFindings": { "type": "number" },
        "runNetworkAudits": { "type": "boolean" },
        "tools": { "type": "array", "items": { "type": "object" } },
        "manifests": { "type": "array", "items": { "type": "object" } },
        "commands": { "type": "array", "items": { "type": "object" } },
        "findings": { "type": "array", "items": { "type": "object" } },
        "severityCounts": { "type": "object" },
        "coverageGaps": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
