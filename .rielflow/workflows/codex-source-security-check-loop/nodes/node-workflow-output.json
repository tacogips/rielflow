{
  "id": "workflow-output",
  "description": "Publish the accepted source security check result.",
  "executionBackend": "codex-agent",
  "model": "gpt-5.5",
  "promptTemplateFile": "prompts/workflow-output.md",
  "variables": {},
  "output": {
    "description": "Return only JSON matching this schema. Schema validation failure must be treated as an invalid output and retried.",
    "maxValidationAttempts": 3,
    "jsonSchema": {
      "type": "object",
      "required": [
        "status",
        "targetPath",
        "scanInputs",
        "methodResults",
        "finalFindings",
        "blockingFindings",
        "fixWorkflowInput",
        "resolvedFindings",
        "falsePositiveFindings",
        "delegatedWorkflowRuns",
        "changedFiles",
        "verification",
        "residualLowRisks",
        "coverageGaps",
        "operatorNotes"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["accepted", "needs_fix", "blocked"] },
        "targetPath": { "type": "string" },
        "scanInputs": {
          "type": "object",
          "required": ["includePaths", "excludePaths", "maxFindings", "runNetworkAudits"],
          "properties": {
            "includePaths": { "type": "array", "items": { "type": "string" } },
            "excludePaths": { "type": "array", "items": { "type": "string" } },
            "maxFindings": { "type": "number" },
            "runNetworkAudits": { "type": "boolean" }
          }
        },
        "methodResults": { "type": "object" },
        "finalFindings": { "type": "array", "items": { "type": "object" } },
        "blockingFindings": { "type": "array", "items": { "type": "object" } },
        "fixWorkflowInput": { "type": ["object", "null"] },
        "resolvedFindings": { "type": "array", "items": { "type": "object" } },
        "falsePositiveFindings": { "type": "array", "items": { "type": "object" } },
        "delegatedWorkflowRuns": { "type": "array", "items": { "type": "object" } },
        "changedFiles": { "type": "array", "items": { "type": "string" } },
        "verification": { "type": "array", "items": { "type": "object" } },
        "residualLowRisks": { "type": "array", "items": { "type": "object" } },
        "coverageGaps": { "type": "array", "items": { "type": "string" } },
        "operatorNotes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
