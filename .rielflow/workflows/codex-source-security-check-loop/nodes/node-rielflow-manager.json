{
  "id": "rielflow-manager",
  "description": "Coordinate the source security check loop.",
  "executionBackend": "codex-agent",
  "model": "gpt-5.5",
  "promptTemplateFile": "prompts/rielflow-manager.md",
  "variables": {},
  "output": {
    "description": "Return only JSON matching this schema. Schema validation failure must be treated as an invalid output and retried.",
    "maxValidationAttempts": 3,
    "jsonSchema": {
      "type": "object",
      "required": ["targetPath", "includePaths", "excludePaths", "runNetworkAudits", "maxFindings", "constraints", "securityMethods", "nextStep"],
      "properties": {
        "targetPath": { "type": "string" },
        "includePaths": { "type": "array", "items": { "type": "string" } },
        "excludePaths": { "type": "array", "items": { "type": "string" } },
        "runNetworkAudits": { "type": "boolean" },
        "maxFindings": { "type": "number" },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "securityMethods": { "type": "array", "items": { "type": "string" } },
        "nextStep": { "type": "string" }
      }
    }
  }
}
