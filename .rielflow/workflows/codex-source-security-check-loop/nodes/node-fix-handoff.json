{
  "id": "fix-handoff",
  "description": "Prepare a delegated security-fix request for codex-design-and-implement-review-loop.",
  "executionBackend": "codex-agent",
  "model": "gpt-5.5",
  "promptTemplateFile": "prompts/fix-handoff.md",
  "variables": {},
  "output": {
    "description": "Return only JSON matching this schema. Schema validation failure must be treated as an invalid output and retried.",
    "maxValidationAttempts": 3,
    "jsonSchema": {
      "type": "object",
      "required": ["workflowInput", "securityContext", "handoffSummary"],
      "properties": {
        "workflowInput": {
          "type": "object",
          "required": ["requestedBehavior", "targetFeatureArea", "targetPath", "includePaths", "excludePaths", "constraints", "verificationPreferences"],
          "properties": {
            "requestedBehavior": { "type": "string" },
            "targetFeatureArea": { "type": "string" },
            "targetPath": { "type": "string" },
            "includePaths": { "type": "array", "items": { "type": "string" } },
            "excludePaths": { "type": "array", "items": { "type": "string" } },
            "constraints": { "type": "array", "items": { "type": "string" } },
            "verificationPreferences": { "type": "array", "items": { "type": "string" } }
          }
        },
        "securityContext": {
          "type": "object",
          "required": ["sourceWorkflowId", "targetPath", "methodResults", "blockingFindings", "falsePositiveFindings", "residualLowRisks", "scanInputs"],
          "properties": {
            "sourceWorkflowId": { "type": "string" },
            "targetPath": { "type": "string" },
            "methodResults": { "type": "object" },
            "blockingFindings": { "type": "array", "items": { "type": "object" } },
            "falsePositiveFindings": { "type": "array", "items": { "type": "object" } },
            "residualLowRisks": { "type": "array", "items": { "type": "object" } },
            "scanInputs": { "type": "object" }
          }
        },
        "handoffSummary": {
          "type": "object",
          "required": ["findingCountBySeverity", "findingCountByMethod", "filesToChange", "mustNotChange", "mustVerify"],
          "properties": {
            "findingCountBySeverity": { "type": "object" },
            "findingCountByMethod": { "type": "object" },
            "filesToChange": { "type": "array", "items": { "type": "string" } },
            "mustNotChange": { "type": "array", "items": { "type": "string" } },
            "mustVerify": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
