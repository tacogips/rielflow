{
  "id": "acceptance-review",
  "description": "Review post-fix deterministic evidence and decide whether another security-fix pass is required.",
  "executionBackend": "codex-agent",
  "model": "gpt-5.5",
  "promptTemplateFile": "prompts/acceptance-review.md",
  "variables": {},
  "output": {
    "description": "Return adapter JSON with when.needs_fix and a payload matching this schema. Schema validation failure must be treated as an invalid output and retried.",
    "maxValidationAttempts": 3,
    "jsonSchema": {
      "type": "object",
      "required": [
        "needs_fix",
        "accepted",
        "methodResults",
        "resolvedFindingIds",
        "remainingFindings",
        "newFindings",
        "falsePositiveFindingIds",
        "deterministicVerification",
        "fixWorkflowInput",
        "residualLowRisks",
        "routingReason"
      ],
      "properties": {
        "needs_fix": { "type": "boolean" },
        "accepted": { "type": "boolean" },
        "methodResults": { "type": "object" },
        "resolvedFindingIds": { "type": "array", "items": { "type": "string" } },
        "remainingFindings": { "type": "array", "items": { "type": "object" } },
        "newFindings": { "type": "array", "items": { "type": "object" } },
        "falsePositiveFindingIds": { "type": "array", "items": { "type": "string" } },
        "deterministicVerification": { "type": "array", "items": { "type": "object" } },
        "fixWorkflowInput": { "type": ["object", "null"] },
        "residualLowRisks": { "type": "array", "items": { "type": "object" } },
        "routingReason": { "type": "string" }
      }
    }
  }
}
