{
  "workflowId": "codex-source-security-check-loop",
  "description": "Run separate deterministic vulnerability-check methods for secrets, static source/SAST, dependency audit, and supply-chain/config risk; triage with Codex; delegate blocking fixes; and rescan until high and medium findings are resolved.",
  "defaults": {
    "maxLoopIterations": 8,
    "nodeTimeoutMs": 3600000,
    "supervision": {
      "monitorIntervalMs": 15000,
      "stallTimeoutMs": 300000
    }
  },
  "prompts": {
    "rielflowPromptTemplate": "Coordinate {{workflowId}}. Start with separate deterministic vulnerability-check methods: secret-pattern heuristics, gitleaks when executable, static source/SAST, dependency audit, and supply-chain/config review. Triage all method evidence and source code. If high or medium security findings remain, package a narrow fix request for codex-design-and-implement-review-loop. After the delegated fix returns, rerun every deterministic method and run acceptance review. Repeat until no high or medium findings remain, then publish output. Low findings may be accepted only when explicitly documented as residual risk.",
    "workerSystemPromptTemplate": "Return concise business JSON only. Keep commands, scanner availability, findings, severity, affected files, fix scope, verification, routing decisions, and residual risks explicit."
  },
  "managerStepId": "rielflow-manager",
  "entryStepId": "rielflow-manager",
  "nodes": [
    {
      "id": "rielflow-manager",
      "nodeFile": "nodes/node-rielflow-manager.json"
    },
    {
      "id": "secret-scan",
      "nodeFile": "nodes/node-secret-scan.json"
    },
    {
      "id": "gitleaks-scan",
      "nodeFile": "nodes/node-gitleaks-scan.json"
    },
    {
      "id": "static-analysis-scan",
      "nodeFile": "nodes/node-static-analysis-scan.json"
    },
    {
      "id": "dependency-audit-scan",
      "nodeFile": "nodes/node-dependency-audit-scan.json"
    },
    {
      "id": "supply-chain-config-scan",
      "nodeFile": "nodes/node-supply-chain-config-scan.json"
    },
    {
      "id": "security-triage",
      "nodeFile": "nodes/node-security-triage.json"
    },
    {
      "id": "exit-gate",
      "nodeFile": "nodes/node-exit-gate.json"
    },
    {
      "id": "fix-handoff",
      "nodeFile": "nodes/node-fix-handoff.json"
    },
    {
      "id": "acceptance-review",
      "nodeFile": "nodes/node-acceptance-review.json"
    },
    {
      "id": "workflow-output",
      "kind": "output",
      "nodeFile": "nodes/node-workflow-output.json"
    }
  ],
  "steps": [
    {
      "id": "rielflow-manager",
      "nodeId": "rielflow-manager",
      "description": "Start the source security check loop.",
      "role": "manager",
      "transitions": [
        {
          "toStepId": "step1-secret-scan"
        }
      ]
    },
    {
      "id": "step1-secret-scan",
      "nodeId": "secret-scan",
      "description": "Run high-confidence secret and private-key checks.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step2-gitleaks-scan"
        }
      ]
    },
    {
      "id": "step2-gitleaks-scan",
      "nodeId": "gitleaks-scan",
      "description": "Run gitleaks when executable and record skipped evidence when unavailable.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step3-static-analysis-scan"
        }
      ]
    },
    {
      "id": "step3-static-analysis-scan",
      "nodeId": "static-analysis-scan",
      "description": "Run deterministic risky-code heuristics and optional Semgrep SAST.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step4-dependency-audit-scan"
        }
      ]
    },
    {
      "id": "step4-dependency-audit-scan",
      "nodeId": "dependency-audit-scan",
      "description": "Run manifest discovery and optional ecosystem dependency audits.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step5-supply-chain-config-scan"
        }
      ]
    },
    {
      "id": "step5-supply-chain-config-scan",
      "nodeId": "supply-chain-config-scan",
      "description": "Run package-script, build-chain, container, and infrastructure configuration heuristics.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step6-security-triage"
        }
      ]
    },
    {
      "id": "step6-security-triage",
      "nodeId": "security-triage",
      "description": "Review all deterministic method evidence and source code against secure-code-review controls.",
      "role": "worker",
      "stallTimeoutMs": 900000,
      "transitions": [
        {
          "toStepId": "step7-exit-gate"
        }
      ]
    },
    {
      "id": "step7-exit-gate",
      "nodeId": "exit-gate",
      "description": "Route to fix handoff when high or medium findings remain; otherwise finish.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step8-fix-handoff",
          "label": "needs_fix"
        },
        {
          "toStepId": "workflow-output",
          "label": "!(needs_fix)"
        }
      ]
    },
    {
      "id": "step8-fix-handoff",
      "nodeId": "fix-handoff",
      "description": "Package blocking security findings into a delegated issue-resolution request.",
      "role": "worker",
      "transitions": [
        {
          "toWorkflowId": "codex-design-and-implement-review-loop",
          "toStepId": "rielflow-manager",
          "resumeStepId": "step9-secret-rescan"
        }
      ]
    },
    {
      "id": "step9-secret-rescan",
      "nodeId": "secret-scan",
      "description": "Rerun secret and private-key checks after delegated fixes.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step10-gitleaks-rescan"
        }
      ]
    },
    {
      "id": "step10-gitleaks-rescan",
      "nodeId": "gitleaks-scan",
      "description": "Rerun gitleaks after delegated fixes when executable.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step11-static-analysis-rescan"
        }
      ]
    },
    {
      "id": "step11-static-analysis-rescan",
      "nodeId": "static-analysis-scan",
      "description": "Rerun static source/SAST checks after delegated fixes.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step12-dependency-audit-rescan"
        }
      ]
    },
    {
      "id": "step12-dependency-audit-rescan",
      "nodeId": "dependency-audit-scan",
      "description": "Rerun dependency audit checks after delegated fixes.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step13-supply-chain-config-rescan"
        }
      ]
    },
    {
      "id": "step13-supply-chain-config-rescan",
      "nodeId": "supply-chain-config-scan",
      "description": "Rerun supply-chain and configuration heuristics after delegated fixes.",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "step14-acceptance-review"
        }
      ]
    },
    {
      "id": "step14-acceptance-review",
      "nodeId": "acceptance-review",
      "description": "Compare initial and post-fix evidence and decide whether another fix loop is required.",
      "role": "worker",
      "stallTimeoutMs": 900000,
      "transitions": [
        {
          "toStepId": "step8-fix-handoff",
          "label": "needs_fix"
        },
        {
          "toStepId": "workflow-output",
          "label": "!(needs_fix)"
        }
      ]
    },
    {
      "id": "workflow-output",
      "nodeId": "workflow-output",
      "description": "Publish the accepted security-check result.",
      "role": "worker"
    }
  ],
  "metadata": {
    "rielflowPackage": {
      "title": "codex-source-security-check-loop",
      "description": "Run separate deterministic vulnerability-check methods for secrets, static source/SAST, dependency audit, and supply-chain/config risk; triage with Codex; delegate blocking fixes; and rescan until high and medium findings are resolved.",
      "tags": [
        "workflow",
        "security",
        "sast"
      ],
      "backends": [
        "native-command",
        "codex-agent"
      ]
    }
  }
}
