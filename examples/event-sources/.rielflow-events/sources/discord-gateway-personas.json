{
  "id": "discord-gateway-personas",
  "kind": "discord-gateway",
  "provider": "discord",
  "tokenEnv": "RIEL_DISCORD_BOT_TOKEN",
  "applicationIdEnv": "RIEL_DISCORD_APPLICATION_ID",
  "guildIds": ["123456789012345678"],
  "channels": [
    {
      "id": "234567890123456789",
      "includeThreads": true,
      "personas": ["yui", "mika", "rina"]
    }
  ],
  "history": {
    "maxMessages": 100,
    "maxBytes": 131072,
    "maxAgeMs": 2592000000,
    "scope": "thread-or-channel",
    "includeBotMessages": false,
    "fetchOnStart": false,
    "fetchOnMessage": "when-cache-empty"
  },
  "filters": {
    "ignoreBots": true,
    "ignoreSelf": true,
    "requireMention": false
  },
  "attachments": {
    "includeImages": true,
    "resolveFilePaths": true,
    "maxBytes": 10485760
  },
  "replyBots": {
    "yui": {
      "tokenEnv": "DISCORD_BOT_TOKEN_YUI_CODEX"
    },
    "mika": {
      "tokenEnv": "DISCORD_BOT_TOKEN_MIKA_TREND"
    },
    "rina": {
      "tokenEnv": "DISCORD_BOT_TOKEN_RINA_CURSOR"
    }
  }
}
