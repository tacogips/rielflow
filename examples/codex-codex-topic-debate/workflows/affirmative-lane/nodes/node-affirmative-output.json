{
  "id": "affirmative-output",
  "executionBackend": "codex-agent",
  "model": "gpt-5.3-codex-spark",
  "promptTemplateFile": "prompts/affirmative-output.md",
  "variables": {
    "stanceLabel": "affirmative"
  },
  "output": {
    "description": "Return the publishable affirmative debate turn for the next conversation step.",
    "jsonSchema": {
      "type": "object",
      "required": ["stance", "argument", "responseToOpponent", "done"],
      "properties": {
        "stance": {
          "type": "string",
          "const": "affirmative"
        },
        "argument": {
          "type": "string"
        },
        "responseToOpponent": {
          "type": "string"
        },
        "done": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
