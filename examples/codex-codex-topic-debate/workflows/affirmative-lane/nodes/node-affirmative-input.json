{
  "id": "affirmative-input",
  "executionBackend": "codex-agent",
  "model": "gpt-5.3-codex-spark",
  "promptTemplateFile": "prompts/affirmative-input.md",
  "variables": {
    "stanceLabel": "affirmative"
  },
  "output": {
    "description": "Return the normalized affirmative debate input as JSON.",
    "jsonSchema": {
      "type": "object",
      "required": ["topic", "role", "opponentClaim"],
      "properties": {
        "topic": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "const": "affirmative"
        },
        "opponentClaim": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
