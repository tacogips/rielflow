{
  "id": "workflow-output",
  "executionBackend": "claude-code-agent",
  "model": "claude-haiku-4-5",
  "promptTemplateFile": "prompts/workflow-output.md",
  "variables": {},
  "output": {
    "description": "Return the final handoff summary for the workflow caller.",
    "jsonSchema": {
      "type": "object",
      "required": [
        "summary",
        "status",
        "changedFiles"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "changedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
