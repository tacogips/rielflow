{
  "id": "workflow-output",
  "executionBackend": "claude-code-agent",
  "model": "claude-haiku-4-5",
  "promptTemplateFile": "prompts/workflow-output.md",
  "variables": {},
  "output": {
    "description": "Return the final published result for the same-node same-session echo demo.",
    "jsonSchema": {
      "type": "object",
      "required": [
        "summary",
        "status",
        "echoText",
        "finalAnswer"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "echoText": {
          "type": "string"
        },
        "finalAnswer": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
