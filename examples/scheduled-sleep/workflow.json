{
  "workflowId": "scheduled-sleep",
  "description": "Minimal workflow that pauses with a scheduled sleep node before continuing.",
  "defaults": {
    "maxLoopIterations": 3,
    "nodeTimeoutMs": 120000
  },
  "entryStepId": "wait",
  "nodes": [
    {
      "id": "wait-node",
      "nodeFile": "nodes/node-wait.json"
    },
    {
      "id": "worker-node",
      "nodeFile": "nodes/node-worker.json"
    }
  ],
  "steps": [
    {
      "id": "wait",
      "nodeId": "wait-node",
      "role": "worker",
      "transitions": [
        {
          "toStepId": "worker",
          "label": "always"
        }
      ]
    },
    {
      "id": "worker",
      "nodeId": "worker-node",
      "role": "worker"
    }
  ]
}
