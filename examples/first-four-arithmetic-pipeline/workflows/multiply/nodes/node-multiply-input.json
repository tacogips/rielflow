{
  "id": "multiply-input",
  "executionBackend": "claude-code-agent",
  "model": "claude-haiku-4-5",
  "promptTemplateFile": "prompts/multiply-input.md",
  "variables": {},
  "output": {
    "description": "Return the addition result together with the third input number for the multiplication worker.",
    "jsonSchema": {
      "type": "object",
      "required": [
        "firstFour",
        "operands",
        "stage"
      ],
      "properties": {
        "stage": {
          "type": "string",
          "const": "multiply-input"
        },
        "firstFour": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "operands": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
