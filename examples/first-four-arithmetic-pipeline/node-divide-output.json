          },
          "minItems": 4,
          "maxItems": 4
        },
        "finalResult": {
          "type": "number"
        },
        "summary": {
          "type": "string"
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "operation": {
                "type": "string"
              },
              "result": {
                "type": "number"
              }
            },
            "required": [
              "operation",
              "result"
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
