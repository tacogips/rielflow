{
  "workflowId": "node-combinations-showcase",
  "description": "Compact reference bundle authored as a linear ordered node list showing command-node, container-node, and repeat-based foreach authoring in one place.",
  "defaults": {
    "maxLoopIterations": 3,
    "nodeTimeoutMs": 120000,
    "containerRuntime": {
      "runnerKind": "podman"
    }
  },
  "prompts": {
    "divedraPromptTemplate": "Coordinate {{workflowId}} as a compact structure showcase. Run the command lane, then the container lane, then the repeat-based foreach lane.",
    "workerSystemPromptTemplate": "Work only on the current node responsibility and return concise workflow JSON-oriented output."
  },
  "nodes": [
    {
      "id": "divedra-manager",
      "role": "manager",
      "nodeFile": "nodes/node-divedra-manager.json"
    },
    {
      "id": "command-manager",
      "group": "command-lane",
      "nodeFile": "nodes/node-command-manager.json"
    },
    {
      "id": "command-input",
      "group": "command-lane",
      "nodeFile": "nodes/node-command-input.json"
    },
    {
      "id": "command-worker",
      "group": "command-lane",
      "nodeFile": "nodes/node-command-worker.json"
    },
    {
      "id": "command-output",
      "group": "command-lane",
      "nodeFile": "nodes/node-command-output.json"
    },
    {
      "id": "container-manager",
      "group": "container-lane",
      "nodeFile": "nodes/node-container-manager.json"
    },
    {
      "id": "container-input",
      "group": "container-lane",
      "nodeFile": "nodes/node-container-input.json"
    },
    {
      "id": "container-worker",
      "group": "container-lane",
      "nodeFile": "nodes/node-container-worker.json"
    },
    {
      "id": "container-output",
      "group": "container-lane",
      "nodeFile": "nodes/node-container-output.json"
    },
    {
      "id": "foreach-manager",
      "group": "foreach-loop",
      "nodeFile": "nodes/node-foreach-manager.json"
    },
    {
      "id": "foreach-input",
      "group": "foreach-loop",
      "nodeFile": "nodes/node-foreach-input.json"
    },
    {
      "id": "foreach-worker",
      "group": "foreach-loop",
      "nodeFile": "nodes/node-foreach-worker.json"
    },
    {
      "id": "foreach-judge",
      "group": "foreach-loop",
      "nodeFile": "nodes/node-foreach-judge.json",
      "repeat": {
        "while": "continue_items",
        "restartAt": "foreach-manager",
        "maxIterations": 3
      }
    },
    {
      "id": "foreach-output",
      "group": "foreach-loop",
      "nodeFile": "nodes/node-foreach-output.json"
    }
  ]
}
