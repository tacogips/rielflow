{
  "workflowId": "codex-codex-euthanasia-debate",
  "description": "Two codex-agent lanes argue euthanasia from opposing positions. After each full affirmative-then-negative round, a judge step decides whether to continue; the mock scenario ends after six rounds (same deterministic depth as the former structural conversation demo).",
  "defaults": {
    "maxLoopIterations": 10,
    "nodeTimeoutMs": 120000
  },
  "prompts": {
    "divedraPromptTemplate": "Run {{workflowId}} as a two-sided debate. Start the affirmative lane, run the negative lane, and let the judge step decide whether another round is needed until the scenario ends the loop.",
    "workerSystemPromptTemplate": "Return concise business JSON that is useful to the next workflow node."
  },
  "managerStepId": "divedra-manager",
  "entryStepId": "divedra-manager",
  "nodes": [
    {
      "id": "divedra-manager",
      "nodeFile": "nodes/node-divedra-manager.json"
    },
    {
      "id": "affirmative-manager",
      "nodeFile": "workflows/affirmative-lane/nodes/node-affirmative-manager.json"
    },
    {
      "id": "affirmative-input",
      "nodeFile": "workflows/affirmative-lane/nodes/node-affirmative-input.json"
    },
    {
      "id": "affirmative-speaker",
      "nodeFile": "workflows/affirmative-lane/nodes/node-affirmative-speaker.json"
    },
    {
      "id": "affirmative-output",
      "nodeFile": "workflows/affirmative-lane/nodes/node-affirmative-output.json"
    },
    {
      "id": "negative-manager",
      "nodeFile": "workflows/negative-lane/nodes/node-negative-manager.json"
    },
    {
      "id": "negative-input",
      "nodeFile": "workflows/negative-lane/nodes/node-negative-input.json"
    },
    {
      "id": "negative-speaker",
      "nodeFile": "workflows/negative-lane/nodes/node-negative-speaker.json"
    },
    {
      "id": "negative-output",
      "nodeFile": "workflows/negative-lane/nodes/node-negative-output.json"
    },
    {
      "id": "debate-judge",
      "nodeFile": "nodes/node-debate-judge.json"
    },
    {
      "id": "debate-summary",
      "nodeFile": "nodes/node-debate-summary.json"
    }
  ],
  "steps": [
    {
      "id": "divedra-manager",
      "nodeId": "divedra-manager",
      "role": "manager",
      "transitions": [{ "toStepId": "affirmative-manager" }]
    },
    {
      "id": "affirmative-manager",
      "nodeId": "affirmative-manager",
      "transitions": [{ "toStepId": "affirmative-input" }]
    },
    {
      "id": "affirmative-input",
      "nodeId": "affirmative-input",
      "transitions": [{ "toStepId": "affirmative-speaker" }]
    },
    {
      "id": "affirmative-speaker",
      "nodeId": "affirmative-speaker",
      "transitions": [{ "toStepId": "affirmative-output" }]
    },
    {
      "id": "affirmative-output",
      "nodeId": "affirmative-output",
      "transitions": [{ "toStepId": "negative-manager" }]
    },
    {
      "id": "negative-manager",
      "nodeId": "negative-manager",
      "transitions": [{ "toStepId": "negative-input" }]
    },
    {
      "id": "negative-input",
      "nodeId": "negative-input",
      "transitions": [{ "toStepId": "negative-speaker" }]
    },
    {
      "id": "negative-speaker",
      "nodeId": "negative-speaker",
      "transitions": [{ "toStepId": "negative-output" }]
    },
    {
      "id": "negative-output",
      "nodeId": "negative-output",
      "transitions": [{ "toStepId": "debate-judge" }]
    },
    {
      "id": "debate-judge",
      "nodeId": "debate-judge",
      "transitions": [
        {
          "toStepId": "affirmative-manager",
          "label": "continue_debate"
        },
        {
          "toStepId": "debate-summary",
          "label": "!(continue_debate)"
        }
      ]
    },
    {
      "id": "debate-summary",
      "nodeId": "debate-summary"
    }
  ]
}
