{
  "workflowId": "matrix-chat-reply",
  "description": "Reply to an Element/Matrix room message with the built-in rielflow chat reply worker add-on.",
  "defaults": {
    "maxLoopIterations": 3,
    "nodeTimeoutMs": 120000
  },
  "entryStepId": "reply-to-matrix",
  "nodes": [
    {
      "id": "reply-to-matrix",
      "addon": {
        "name": "rielflow/chat-reply-worker",
        "version": "1",
        "config": {
          "textTemplate": "Matrix sample received from {{event.actor.displayName}}: {{event.input.text}}",
          "visibility": "public",
          "threadPolicy": "same-thread"
        }
      }
    }
  ],
  "steps": [
    {
      "id": "reply-to-matrix",
      "nodeId": "reply-to-matrix",
      "role": "worker"
    }
  ]
}
