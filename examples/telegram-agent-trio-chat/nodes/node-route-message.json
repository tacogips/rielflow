{
  "id": "route-message",
  "description": "Select exactly one initial persona for the incoming Telegram message. Yui is the default when no persona is explicitly named.",
  "executionBackend": "codex-agent",
  "model": "gpt-5.4-mini",
  "promptTemplateFile": "prompts/route-message.md",
  "variables": {
    "codexAdditionalArgs": ["--ignore-rules"],
    "forwardImageAttachments": false
  },
  "output": {
    "description": "Return payload.target plus adapter-level when flags used by transition labels.",
    "jsonSchema": {
      "type": "object",
      "required": ["target", "target_yui", "target_mika", "target_rina"],
      "properties": {
        "target": {
          "type": "string",
          "enum": ["yui", "mika", "rina"]
        },
        "reason": {
          "type": "string"
        },
        "target_yui": {
          "type": "boolean"
        },
        "target_mika": {
          "type": "boolean"
        },
        "target_rina": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
