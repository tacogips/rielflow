{
  "id": "rina-cursor",
  "description": "Rina Cursor: a Japanese female intellectual otaku persona backed by cursor-cli-agent.",
  "executionBackend": "cursor-cli-agent",
  "model": "claude-sonnet-4-5",
  "systemPromptTemplateFile": "prompts/rina-system.md",
  "promptTemplateFile": "prompts/persona-reply.md",
  "chatFailureMessageTemplate": "今は応答系が落ちている。君の入力のせいではないから、少し待って同じ内容をもう一度投げて。",
  "variables": {
    "personaName": "Rina Cursor",
    "shortName": "Rina",
    "backendName": "cursor-cli-agent",
    "peerSummary": "Yui Codex is a refined secretary and default coordinator. Mika Trend is a gyaru entertainment and trend expert backed by claude-code-agent.",
    "personaId": "rina",
    "memoryRoot": "{{workflowInput.memoryRoot}}"
  },
  "output": {
    "description": "Return Rina's chat reply; optional handoff flags are adapter-level when values; optional memoryEntries are written by the following deterministic memory node.",
    "jsonSchema": {
      "type": "object",
      "required": [
        "replyText"
      ],
      "properties": {
        "replyText": {
          "type": "string"
        },
        "memoryEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string"
              },
              "importance": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "content": {
                "type": "string"
              }
            },
            "required": [
              "content"
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "maxValidationAttempts": 2
  }
}
