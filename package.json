{
  "name": "divedra",
  "version": "0.1.0",
  "description": "no",
  "type": "module",
  "main": "dist/main.js",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "bun run build:server && bun run build:ui",
    "build:server": "bun build src/main.ts --outdir dist --target bun",
    "build:ui": "bash ./scripts/require-node-tooling.sh node ./scripts/run-ui-build.mjs",
    "typecheck:server": "tsc --noEmit",
    "typecheck:ui": "bash ./scripts/require-node-tooling.sh node ./scripts/run-ui-typecheck.mjs",
    "ui:framework": "bash ./scripts/require-node-tooling.sh node ./scripts/run-ui-framework-status.mjs",
    "start": "bun run src/main.ts",
    "test": "bash ./scripts/run-bun-tests.sh",
    "test:e2e": "bun run build:ui && bash ./scripts/require-node-tooling.sh node ./scripts/run-ui-e2e.mjs",
    "test:all": "bun run test && bun run build:ui && bun run test:e2e",
    "test:watch": "bash ./scripts/run-bun-tests.sh --watch",
    "test:ui": "bash ./scripts/require-node-tooling.sh node ./scripts/run-ui-vitest.mjs",
    "test:ui:interactive": "bash ./scripts/require-node-tooling.sh node ./scripts/run-ui-vitest-ui.mjs",
    "check:ui": "bun run typecheck:ui && bun run build:ui",
    "typecheck": "bun run typecheck:server && bun run typecheck:ui",
    "lint": "bun run typecheck",
    "format": "bash ./scripts/require-node-tooling.sh node ./scripts/run-prettier.mjs --write \"src/**/*.ts\" \"ui/**/*.ts\" \"ui/**/*.tsx\" \"scripts/**/*.mjs\" \"e2e/**/*.cjs\" \"playwright.config.cjs\"",
    "format:check": "bash ./scripts/require-node-tooling.sh node ./scripts/run-prettier.mjs --check \"src/**/*.ts\" \"ui/**/*.ts\" \"ui/**/*.tsx\" \"scripts/**/*.mjs\" \"e2e/**/*.cjs\" \"playwright.config.cjs\"",
    "clean": "rm -rf dist ui/dist"
  },
  "homepage": "https://github.com/user/repo",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/repo"
  },
  "license": "MIT",
  "trustedDependencies": [],
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "claude-code-agent": "github:tacogips/claude-code-agent#fd9634695b9369902cc1ee01960dd39cbc300b85",
    "codex-agent": "github:tacogips/codex-agent#23cd34cbec18ae10b1868ec154c088b6a2f1c8c1",
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1",
    "openai": "6.27.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.1",
    "@types/bun": "1.1.14",
    "@vitest/ui": "2.1.8",
    "prettier": "3.4.2",
    "solid-js": "^1.9.9",
    "typescript": "5.7.2",
    "vite": "^5.4.21",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "2.1.8"
  }
}
