{
  "name": "divedra",
  "version": "0.1.0",
  "description": "TypeScript/Bun workflow runtime for cooperative multi-agent execution",
  "type": "module",
  "main": "dist/lib.js",
  "module": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js",
      "default": "./dist/lib.js"
    },
    "./cli": {
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "bun run build:server",
    "build:server": "bun build src/main.ts src/lib.ts --outdir dist --target bun && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -rf dist/prompts && cp -R src/workflow/prompts dist/prompts",
    "typecheck:server": "tsc --noEmit",
    "start": "bun run src/main.ts",
    "test": "bash ./scripts/run-bun-tests.sh",
    "test:all": "bun run test",
    "test:watch": "bash ./scripts/run-bun-tests.sh --watch",
    "typecheck": "bun run typecheck:server",
    "lint": "bun run typecheck",
    "format": "prettier --ignore-unknown --write \"src/**/*.{ts,tsx}\" \"scripts/**/*\" \"*.{md,json}\"",
    "format:check": "prettier --ignore-unknown --check \"src/**/*.{ts,tsx}\" \"scripts/**/*\" \"*.{md,json}\"",
    "clean": "rm -rf dist"
  },
  "homepage": "https://github.com/user/repo",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/repo"
  },
  "license": "MIT",
  "trustedDependencies": [],
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "claude-code-agent": "github:tacogips/claude-code-agent#c89d9bc5d8917b60b65e4b28cc12f5e507fa005a",
    "codex-agent": "github:tacogips/codex-agent#83c3c2b6445df3d31b047b93d27a4bfe3e64ddcb",
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1",
    "openai": "6.27.0"
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
