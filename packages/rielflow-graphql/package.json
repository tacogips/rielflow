{
  "name": "rielflow-graphql",
  "version": "0.1.0",
  "description": "GraphQL control-plane contracts and public DTOs for Rielflow",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./control-plane-service": {
      "types": "./dist/control-plane-service.d.ts",
      "import": "./dist/control-plane-service.js",
      "default": "./dist/control-plane-service.js"
    },
    "./dto": {
      "types": "./dist/dto.d.ts",
      "import": "./dist/dto.js",
      "default": "./dist/dto.js"
    },
    "./schema-contract": {
      "types": "./dist/schema-contract.d.ts",
      "import": "./dist/schema-contract.js",
      "default": "./dist/schema-contract.js"
    }
  },
  "dependencies": {
    "graphql": "16.13.1"
  },
  "scripts": {
    "build": "bun run --cwd ../.. build:server",
    "typecheck": "bun run --cwd ../.. typecheck"
  },
  "license": "MIT"
}
