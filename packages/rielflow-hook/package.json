{
  "name": "rielflow-hook",
  "version": "0.1.25",
  "description": "Agent hook parsing, vendor detection, handler, and recorder contracts for Rielflow",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "default": "./dist/context.js"
    },
    "./detect-vendor": {
      "types": "./dist/detect-vendor.d.ts",
      "import": "./dist/detect-vendor.js",
      "default": "./dist/detect-vendor.js"
    },
    "./dispatch": {
      "types": "./dist/dispatch.d.ts",
      "import": "./dist/dispatch.js",
      "default": "./dist/dispatch.js"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "import": "./dist/handler.js",
      "default": "./dist/handler.js"
    },
    "./parse": {
      "types": "./dist/parse.d.ts",
      "import": "./dist/parse.js",
      "default": "./dist/parse.js"
    },
    "./recorder-contracts": {
      "types": "./dist/recorder-contracts.d.ts",
      "import": "./dist/recorder-contracts.js",
      "default": "./dist/recorder-contracts.js"
    },
    "./redaction": {
      "types": "./dist/redaction.d.ts",
      "import": "./dist/redaction.js",
      "default": "./dist/redaction.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "bun run --cwd ../.. build:server",
    "typecheck": "bun run --cwd ../.. typecheck"
  },
  "dependencies": {
    "rielflow-core": "workspace:*"
  },
  "license": "MIT"
}
