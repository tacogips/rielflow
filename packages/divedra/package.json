{
  "name": "divedra",
  "version": "0.1.0",
  "description": "Compatibility facade for the divedra CLI and public library API",
  "type": "module",
  "main": "dist/lib.js",
  "module": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js",
      "default": "./dist/lib.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "bin": {
    "divedra": "dist/main.js"
  },
  "scripts": {
    "build": "bun run --cwd ../.. build:server",
    "typecheck": "bun run --cwd ../.. typecheck",
    "start": "bun run dist/main.js"
  },
  "dependencies": {
    "divedra-addons": "workspace:*",
    "divedra-core": "workspace:*",
    "divedra-events": "workspace:*",
    "divedra-graphql": "workspace:*",
    "divedra-server": "workspace:*",
    "divedra-hook": "workspace:*"
  },
  "license": "MIT"
}
