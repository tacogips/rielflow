{
  "name": "rielflow-adapters",
  "version": "0.1.2",
  "description": "Agent backend adapters and dispatch registry for Rielflow",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run --cwd ../.. build:server",
    "typecheck": "bun run --cwd ../.. typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "claude-code-agent": "github:tacogips/claude-code-agent#eb3d81d3499df77695cc3b0ed92da73fc5b21f4e",
    "codex-agent": "github:tacogips/codex-agent#3f6bbea86a0f4822ff7fdc88079097fd51575bbe",
    "cursor-cli-agent": "github:tacogips/cursor-cli-agent#b14a00e5008cceae6debb73c986aa793671ff8ef",
    "openai": "6.27.0",
    "rielflow-core": "workspace:*"
  },
  "license": "MIT"
}
