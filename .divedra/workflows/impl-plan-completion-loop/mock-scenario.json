{
  "divedra-manager": {
    "provider": "scenario-mock",
    "model": "gpt-5.5",
    "when": {
      "always": true
    },
    "payload": {
      "planPath": "impl-plans/active/example-complete-plan.md",
      "targetTasks": [],
      "constraints": [
        "Do not stage, commit, push, or revert unrelated dirty worktree changes."
      ]
    }
  },
  "step1-plan-assess": {
    "provider": "scenario-mock",
    "model": "scenario-command",
    "when": {
      "plan_complete": true
    },
    "payload": {
      "planPath": "impl-plans/active/example-complete-plan.md",
      "plan_complete": true,
      "completedTasks": ["TASK-001"],
      "incompleteTasks": [],
      "nextTaskId": null,
      "implementationRequired": false,
      "verificationCommands": [
        "bun test src/workflow/engine.test.ts -t plan-completion-loop"
      ],
      "residualRisks": []
    }
  },
  "step4-archive-completed-plans": {
    "provider": "scenario-mock",
    "model": "scenario-command",
    "when": {
      "always": true
    },
    "payload": {
      "archivedPlanPaths": [
        "impl-plans/completed/example-complete-plan.md"
      ],
      "skippedPlanPaths": [],
      "activePlansRemaining": [],
      "indexUpdated": true,
      "dryRun": false
    }
  },
  "workflow-output": {
    "provider": "scenario-mock",
    "model": "gpt-5.5",
    "when": {
      "always": true
    },
    "payload": {
      "planPath": "impl-plans/completed/example-complete-plan.md",
      "completedTaskIds": ["TASK-001"],
      "verificationEvidence": [
        {
          "command": "mock completed-plan assessment and archive",
          "result": "passed"
        }
      ],
      "changedFiles": [
        "impl-plans/completed/example-complete-plan.md",
        "impl-plans/README.md"
      ],
      "residualRisks": []
    }
  }
}
